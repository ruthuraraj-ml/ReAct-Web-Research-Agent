# ==========================================
# 🔐 Security & Environment Configurations
# ==========================================
# Avoid pushing raw secrets, tokens, and API credentials
.env
*.env
env.env
secrets.json

# ==========================================
# 🐍 Python Environment & Runtime Caches
# ==========================================
# Virtual environments
.venv/
venv/
ENV/
env/

# Python compiled bytecode cache folders
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# ==========================================
# 📊 Project-Specific Operational Outputs
# ==========================================
# Keeps your workspace pristine by ignoring your local research log dumps
outputs/report.md
outputs/trace.md

# NOTE: If you want to allow a generic sample directory inside outputs/ 
# but keep actual dynamically written markdown out, leave the folder open:
# outputs/*
# !outputs/placeholder.txt

# ==========================================
# 💻 Operating System & IDE Artifacts
# ==========================================
# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Windows system files
Thumbs.db
Ehthumbs.db
Desktop.ini

# IDE Settings (VS Code, PyCharm, etc.)
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ==========================================
# 📈 Streamlit Runtime Artifacts
# ==========================================
.streamlit/config.toml
.streamlit/secrets.toml
